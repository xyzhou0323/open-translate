{
  "name": "nd-translate",
  "version": "1.0.0",
  "description": "Web page translation extension with neurodiversity terminology glossary, compatible with OpenAI-compatible API. Supports Edge/Chrome.",
  "author": "XyZ",
  "main": "src/background/background.js",
  "scripts": {
    "prebuild": "npm install && npm run setup-vendor",
    "build": "node scripts/build.js",
    "setup-vendor": "node scripts/setup-vendor.js",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-store-assets": "node scripts/generate-store-assets.js",
    "generate-all-assets": "npm run generate-icons && npm run generate-store-assets",
    "validate": "node scripts/build.js",
    "dev": "npm run setup-vendor && echo 'Vendor dependencies ready. Load the extension in Chrome developer mode from this directory'",
    "prepackage": "npm run build",
    "package": "node scripts/package.js",
    "package:zip": "node scripts/package.js --format=zip",
    "package:crx": "node scripts/package.js --format=crx"
  },
  "keywords": [
    "chrome-extension",
    "translation",
    "openai",
    "web-translation",
    "browser-extension",
    "multilingual"
  ],
  "author": "XyZ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sxueck/open-translate.git"
  },
  "bugs": {
    "url": "https://github.com/sxueck/open-translate/issues"
  },
  "homepage": "https://github.com/sxueck/open-translate#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  },
  "manifest": {
    "version": 3,
    "name": "Open Translate",
    "description": "A powerful web page translation extension with OpenAI API compatibility"
  },
  "chrome-extension": {
    "manifest_version": 3,
    "permissions": [
      "activeTab",
      "storage",
      "contextMenus"
    ],
    "host_permissions": [
      "http://*/*",
      "https://*/*"
    ]
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0"
  }
}
